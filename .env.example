# Database Configuration
DB_HOST=localhost
DB_NAME=database_name
DB_USER=user
DB_PASS=secure_password_here

# Bitrix24 Configuration
# Webhook URL with REST token from Bitrix24 portal
BITRIX_WEBHOOK=https://your-portal.bitrix24.com/rest/1/webhook_token_here/
BITRIX_CATALOG_WEBHOOK=https://your-portal.bitrix24.com/rest/1/catalog_webhook_token_here/

# Bitrix24 Portal Domain (for deal links)
BITRIX_PORTAL_DOMAIN=your-portal.bitrix24.com

# Webhook Security
# Set this to a secure random token for webhook validation
# Pass this token in X-Webhook-Secret header with incoming webhooks
BITRIX_WEBHOOK_SECRET=your_secure_webhook_secret_token

# Stock Receipt API Configuration
STOCK_RECEIPT_API_SECRET=your_stock_receipt_api_secret

# Notes:
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to version control
# 3. Keep secrets secure and rotate them regularly
# 4. Use strong random strings for API secrets
